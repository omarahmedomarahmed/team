# Copy to .env and fill in. In production these are set in Vercel project settings.

# Neon Postgres connection string (use the pooled URL for serverless).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Secret used to sign God Mode admin sessions. Generate with:
#   openssl rand -hex 32
AUTH_SECRET=""

# First admin account, created by `npm run db:seed`.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD=""
