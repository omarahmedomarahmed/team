# Copy to .env and fill in. In production these are set in Vercel project settings.

# Neon Postgres connection string. You can paste the SAME Neon string into both
# DATABASE_URL and DIRECT_URL. (DIRECT_URL is used to create tables on deploy.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Secret used to sign God Mode admin sessions. Generate with:
#   openssl rand -hex 32
AUTH_SECRET=""

# First admin account, created by `npm run db:seed`.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD=""
