// =============================================================================
//  TEAM PLATFORM — DATA MODEL
//  Philosophy: nothing that may change is hardcoded. The frontend is a
//  rendering engine; all content, branding, navigation, SEO and feature
//  toggles live here in the database and are managed from God Mode.
//  Templating: SiteSettings + Module (feature flags) make one codebase serve
//  any client — clone, reseed, toggle modules.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Used by `prisma db push` during deploy (Neon's direct, non-pooled URL).
  // You may set DIRECT_URL to the same value as DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

// ----------------------------- Enums ----------------------------------------

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum UserRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

enum SectionType {
  HERO
  STATS
  ABOUT
  SERVICES
  PROCESS
  PORTFOLIO
  TEAM
  TESTIMONIALS
  INDUSTRIES
  FAQ
  CTA
  CONTACT
  LOGOS
  RICH_TEXT
  CUSTOM
}

enum NavLocation {
  HEADER
  FOOTER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}

// ----------------------- Global configuration -------------------------------

/// Single-row global configuration for the whole site (brand, contact, SEO).
model SiteSettings {
  id          String  @id @default(cuid())
  siteName    String
  legalName   String?
  tagline     String?
  description String?
  logoText    String?
  logoUrl     String?
  faviconUrl  String?
  foundedYear Int?

  // Brand / theme tokens (consumed as CSS variables)
  primaryColor String @default("#7c3aed")
  accentColor  String @default("#22d3ee")
  bgColor      String @default("#080711")
  fgColor      String @default("#ECECF1")
  fontHeading  String @default("Inter")
  fontBody     String @default("Inter")

  // Contact
  email   String?
  phone   String?
  address String?
  socials Json    @default("[]") // [{ platform, url }]

  // Market positioning (per client)
  mainMarket   String?
  subMarket    String?
  serviceAreas Json    @default("[]") // ["ALL"] or ["CA","TX",...]

  // Contact form configuration (no-code form builder)
  contactConfig Json @default("{}")

  // SEO defaults
  metaTitle       String?
  metaDescription String?
  ogImageUrl      String?

  // Analytics / tracking
  gaId        String?
  metaPixelId String?

  extra     Json     @default("{}") // escape hatch for future fields
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Feature flags. The mechanism that makes the platform templateable per
/// client: disable a module and it vanishes from both the site and God Mode.
model Module {
  id        String   @id @default(cuid())
  key       String   @unique // services | portfolio | team | testimonials | blog | contact | ai_blog | industries | faq
  label     String
  enabled   Boolean  @default(true)
  config    Json     @default("{}")
  order     Int      @default(0)
  updatedAt DateTime @updatedAt
}

/// Fully editable navigation (header + footer), supports nesting.
model NavItem {
  id        String      @id @default(cuid())
  label     String
  url       String
  location  NavLocation @default(HEADER)
  order     Int         @default(0)
  openInNew Boolean     @default(false)
  enabled   Boolean     @default(true)
  parentId  String?
  parent    NavItem?    @relation("NavChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children  NavItem[]   @relation("NavChildren")
}

// --------------------------- Pages & Sections -------------------------------

/// No page is hardcoded. Admins create unlimited pages, each a stack of
/// reusable sections.
model Page {
  id              String        @id @default(cuid())
  slug            String        @unique
  title           String
  status          PublishStatus @default(PUBLISHED)
  isHome          Boolean       @default(false)
  metaTitle       String?
  metaDescription String?
  ogImageUrl      String?
  noIndex         Boolean       @default(false)
  showInNav       Boolean       @default(false)
  navLabel        String?
  order           Int           @default(0)
  publishedAt     DateTime?
  sections        Section[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

/// A configurable block on a page. `data` holds content, `style` holds
/// presentation — both JSON so any section can evolve without a migration.
model Section {
  id          String      @id @default(cuid())
  page        Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  pageId      String
  type        SectionType
  order       Int         @default(0)
  enabled     Boolean     @default(true)
  // Per-section background (image or video) — editable in God Mode.
  bgImageUrl  String?
  bgVideoUrl  String?
  bgPosterUrl String?
  bgOverlay   Int         @default(72) // overlay darkness %, keeps text readable
  data        Json        @default("{}")
  style       Json        @default("{}")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([pageId, order])
}

// ------------------------- Content collections ------------------------------

model Service {
  id              String        @id @default(cuid())
  slug            String        @unique
  title           String
  summary         String?
  description     String?
  icon            String?
  imageUrl        String?
  featured        Boolean       @default(false)
  order           Int           @default(0)
  status          PublishStatus @default(PUBLISHED)
  // Landing-page fields (each service detail is its own landing page)
  tagline         String?
  heroImageUrl    String?
  benefits        Json          @default("[]") // [{ title, description }]
  gallery         Json          @default("[]") // image URLs
  price           String?
  priceNote       String?
  ctaTitle        String?
  ctaText         String?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model TeamMember {
  id         String        @id @default(cuid())
  name       String
  role       String
  department String?
  bio        String?
  photoUrl   String?
  socials    Json          @default("[]")
  order      Int           @default(0)
  status     PublishStatus @default(PUBLISHED)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model Project {
  id              String        @id @default(cuid())
  slug            String        @unique
  title           String
  client          String?
  industry        String?
  summary         String?
  description     String?
  coverUrl        String?
  gallery         Json          @default("[]")
  services        Json          @default("[]") // tag list
  results         Json          @default("[]") // [{ label, value }]
  year            Int?
  url             String?
  featured        Boolean       @default(false)
  order           Int           @default(0)
  status          PublishStatus @default(PUBLISHED)
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Testimonial {
  id        String        @id @default(cuid())
  author    String
  role      String?
  company   String?
  quote     String
  avatarUrl String?
  rating    Int           @default(5)
  featured  Boolean       @default(false)
  order     Int           @default(0)
  status    PublishStatus @default(PUBLISHED)
  createdAt DateTime      @default(now())
}

model Industry {
  id      String  @id @default(cuid())
  name    String
  slug    String  @unique
  icon    String?
  order   Int     @default(0)
  enabled Boolean @default(true)
}

model Faq {
  id       String        @id @default(cuid())
  question String
  answer   String
  category String?
  order    Int           @default(0)
  status   PublishStatus @default(PUBLISHED)
}

model Post {
  id              String        @id @default(cuid())
  slug            String        @unique
  title           String
  excerpt         String?
  body            String?
  coverUrl        String?
  author          String?
  tags            Json          @default("[]")
  aiGenerated     Boolean       @default(false)
  status          PublishStatus @default(DRAFT)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model MediaAsset {
  id        String   @id @default(cuid())
  url       String? // public URL; for uploads this is /api/media/{id}
  data      Bytes? // uploaded file bytes (stored in the database)
  filename  String
  mimeType  String?
  size      Int?
  width     Int?
  height    Int?
  alt       String?
  folder    String?
  tags      Json     @default("[]")
  createdAt DateTime @default(now())
}

// ----------------------- Leads / form submissions ---------------------------

model Lead {
  id        String     @id @default(cuid())
  name      String?
  email     String?
  phone     String?
  company   String?
  message   String?
  source    String?
  payload   Json       @default("{}")
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())
}

// ------------------------ Admin users & activity ----------------------------

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String
  role         UserRole      @default(ADMIN)
  active       Boolean       @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime      @default(now())
  activity     ActivityLog[]
}

model ActivityLog {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  action    String
  entity    String?
  entityId  String?
  meta      Json     @default("{}")
  createdAt DateTime @default(now())
}
